# Keep the build context small and NEVER ship secrets/data or host-built artifacts.
# The image reinstalls node_modules and rebuilds dist / the MCP servers from source.

# Secrets & user data — must never enter the image
.env
.env.*
!.env.example
server/.data/

# Host-installed deps (reinstalled clean in the image)
node_modules/
**/node_modules/

# Host build output (rebuilt in the image)
dist/
docs-site/out/
docs-site/.next/
docs-site/.source/
server/mcp/gcloud-mcp/**/dist/
deploy/*/dist/
deploy/*/out/

# VCS / OS / scratch
.git/
.github/
*.log
.DS_Store
videos/
