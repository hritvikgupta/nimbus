# Nimbus environment — copy to .env and fill in. NEVER commit the real .env.
# The `api` script loads this via `node --env-file-if-exists=.env`.

# ── Security (required in production) ─────────────────────────────────────────
# Master key for encrypting cloud credentials at rest (AES-256-GCM). Base64 32 bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NIMBUS_ENC_KEY=

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=databricks            # databricks | openrouter
LLM_MODEL=
# Databricks (primary)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_MODEL=
# OpenRouter (cross-provider fallback)
OPENROUTER_API_KEY=

# ── Integrations ─────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=                  # GitHub (and other app) connections
GITHUB_TOKEN=                      # optional, for higher GitHub rate limits
GOOGLE_OAUTH_CLIENT_ID=            # GCP "Connect with Google" (keyless OAuth)
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Fly (rented machines / provisioning) ─────────────────────────────────────
FLY_API_TOKEN=
FLY_ORG=personal
FLY_REGION=iad
FLY_APP=
FLY_MACHINE_IMAGE=

# ── App config ───────────────────────────────────────────────────────────────
AGENT_PORT=8788
APP_URL=http://localhost:5280
ALLOW_SIGNUP=true                  # set false on public deploys to close registration
AGENT_DAILY_LIMIT=50               # per-user daily cap on expensive agent/cloud actions
CORS_ORIGINS=                      # comma-separated allowlist; empty = same-origin only
DOCS_HOST=                         # extra host to serve docs from (besides docs.*)
OPS_SCAN_MINUTES=                  # >0 enables the scheduled incident scan
WEBHOOK_BASE=                      # public base URL for inbound webhooks
